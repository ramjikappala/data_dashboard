name: Cloud Code Runner

on:
  push:
    branches: [ main ]
  schedule:
    # 7:00 PM IST is 1:30 PM UTC
    - cron: '30 13 * * *'
  workflow_dispatch: 

# FORCES THE RUNNER TO USE NODE.JS 24 TO FIX THE DEPRECATION WARNING
env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    
    steps:
      - name: Grab my project files
        uses: actions/checkout@v4

      - name: Install Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.x'

      - name: Install Libraries
        run: |
          pip install requests pandas openpyxl

      - name: Run my Python script!
        # Make sure this matches your file name (e.g., step_1 or build_dashboard.py)
        run: python build_dashboard.py

      - name: Save the new website to GitHub
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add index.html
          git commit -m "Robot auto-updated the dashboard" || echo "No changes to commit"
          git push
