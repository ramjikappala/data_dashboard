import requests
import pandas as pd
from datetime import datetime
from io import BytesIO

# 1. FETCH DATA
target_date = datetime.now().strftime("%d%m%Y")
url = f"https://nseindia.com_{target_date}.csv"
response = requests.get(url, headers={'User-Agent': 'Mozilla/5.0'})

if response.status_code == 200:
    df = pd.read_csv(BytesIO(response.content))
    df.columns = df.columns.str.strip()
    filtered_df = df[df['SERIES'].astype(str).str.strip() == 'EQ']
    # Create the HTML table from data
    stock_table = filtered_df.head(20).to_html(index=False, classes='data-table')
    message = f"Displaying top 20 stocks for {target_date}"
else:
    stock_table = "<h2>Market is closed or data unavailable today.</h2>"
    message = "NSE Fetch Failed"

# 2. CREATE DASHBOARD LOOK
html_content = f"""
<!DOCTYPE html>
<html>
<head>
    <title>NSE Dashboard</title>
    <style>
        body {{ font-family: Arial; text-align: center; background: #121212; color: white; }}
        .data-table {{ margin: 20px auto; border-collapse: collapse; background: #1e1e1e; color: white; }}
        th {{ background: #4CAF50; padding: 12px; }}
        td {{ border: 1px solid #333; padding: 8px; }}
    </style>
</head>
<body>
    <h1>ߓ My NSE Cloud Dashboard</h1>
    <p>{message}</p>
    {stock_table}
    <p>Last Update: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}</p>
</body>
</html>
"""

# 3. SAVE THE DASHBOARD
with open("index.html", "w") as file:
    file.write(html_content)

