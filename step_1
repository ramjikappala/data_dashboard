import datetime

# Get the current time
now = datetime.datetime.now()

# Create the look of our website
html_content = f"""
<!DOCTYPE html>
<html>
<head>
    <title>My Cloud Dashboard</title>
</head>
<body style="font-family: Arial, sans-serif; text-align: center; background-color: #222; color: white; margin-top: 100px;">
    <h1>ߚ My Awesome Cloud Dashboard</h1>
    <p>This website is automatically generated by a cloud robot!</p>
    <div style="background-color: #444; padding: 20px; border-radius: 10px; display: inline-block;">
        <h2>Last Updated:</h2>
        <h3 style="color: #4CAF50;">{now}</h3>
    </div>
</body>
</html>
"""

# Save this code into an HTML file
with open("index.html", "w") as file:
    file.write(html_content)

print("Dashboard built successfully!")
